      "id": "ct_logs-admin-host-certificate-search-d367d18bc9",
      "name": "Admin Host Certificate Search",
      "category": "CT Logs",
      "engine": "crt.sh",
      "description": "Searches certificate transparency records for `admin.{domain}`. This helps identify current or historical hostnames that appeared in public certificate issuance.",
      "query_template": "admin.{domain}",
      "variables": [
        {
          "name": "domain",
          "description": "Primary target domain or hostname.",
          "required": true,
          "example": "example.com"
        }
      ],
      "tags": [
        "certificates",
        "crt-sh",
        "ct-logs",
        "history",
        "subdomains"
      ],
      "example": "admin.example.com",
      "safe_mode": true,
      "reference": "https://crt.sh/",
      "launch_url": "https://crt.sh/?q=admin.{domain}"
    },
